---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import portrait from "../assets/michael-gilsinan.png";
import musicSchoolMap from "../assets/music-school-map.png";
import musicSchoolInstruments from "../assets/music-school-instruments.png";
import stackVolume from "../assets/stack-volume-trend.png";
import stackCoach from "../assets/stack-coach.png";
import stackPlan from "../assets/stack-plan.png";

const LINKEDIN = "https://www.linkedin.com/in/michaelgilsinan";
const GITHUB = "https://github.com/mgilsinan";
const STACK_URL = "https://apps.apple.com/us/app/st-ck/id6768111057";

const projects = [
  {
    label: "2020 — present · Sitemetric",
    title: "Data infrastructure for a construction intelligence platform",
    text: "Sitemetric helps owners, general contractors, and subcontractors manage projects through real-time data, AI, and connected field operations. Today, the platform supports more than 1 million workers and 16,000 contractors across 40 states. I've helped build the company's data infrastructure—from pipelines and reporting systems to analytics that turn operational data into business decisions. My roles have included SVP of Customer Experience and Senior Data Engineer. Today, I serve as Director of Strategic Projects, reporting directly to the CEO.",
    meta: ["Data infrastructure", "Reporting", "GTM", "Construction tech"],
    link: "https://www.sitemetric.com/",
    linkLabel: "Sitemetric",
    featured: true,
  },
  {
    label: "2010 — 2020 · Founder",
    title: "Fort Lee School of Music",
    text: "Opened Fort Lee School of Music during the second year of my undergraduate studies and grew it to two locations in Fort Lee, New Jersey, and New York City. The expansion included raising capital, hiring architects, and overseeing the full gut renovation and build-out of a street-level Manhattan retail space. At its peak, the school employed 30 teachers and staff, delivered more than 300 classes per week, and produced events at the DiMenna Center, Baruch College, and other venues.",
    meta: ["Founder", "Two locations", "30 staff", "300+ classes / week"],
    link: "https://www.fortleemusicschool.com/",
    linkLabel: "Fort Lee School of Music",
    visuals: [
      {
        src: musicSchoolMap,
        alt: "Map of the New York / New Jersey metro area with orange markers showing where 1,419 students came from, clustered densely around Fort Lee and upper Manhattan.",
        caption: "Where they came from — 1,419 students across the NY / NJ metro.",
      },
      {
        src: musicSchoolInstruments,
        alt: "The same metro map with markers colored by instrument — piano, guitar, and voice the most common — led by 461 piano and 322 guitar students.",
        caption: "Enrollment spanned nine instruments, led by piano, guitar, voice, and violin.",
      },
    ],
  },
  {
    label: "Weekend project · iOS",
    title: "Stack",
    text: "A strength-training app I built for myself to support my own workouts while practicing how to ship real products. Built with React Native and Expo, with a Railway backend, RevenueCat for subscriptions, Resend for transactional email, and Xcode for App Store submission. I’m not chasing user growth—the point is to keep exercising, building, launching, and maintaining something end to end.",
    meta: ["React Native", "Expo", "Railway", "RevenueCat", "Resend"],
    link: STACK_URL,
    linkLabel: "View on App Store",
    gallery: [
      { src: stackPlan, alt: "Stack app — workout plan screen with a body map and per-day muscle checklist." },
      { src: stackCoach, alt: "Stack app — the built-in aiCoach answering a training question about rest between sets." },
      { src: stackVolume, alt: "Stack app — weekly volume trend for bench press with an expanded per-set history." },
    ],
  },
];

const background = [
  {
    text: "Started college as a performance major. By my second year, I had founded Fort Lee School of Music and was hiring classmates to teach. Over the next decade, it grew from a small local studio into a two-location music school serving families across New Jersey and New York City.",
  },
  {
    text: "During the COVID shutdown, I returned to school for a second master's degree in Applied Analytics with a concentration in Management. I have one class remaining and expect to graduate in Fall 2026. I also completed focused Python training in data science, automation, machine learning, and dashboard development.",
  },
  {
    text: "Joined Sitemetric in 2020 as a Data Control Officer. Since then, I've served as SVP of Customer Experience, Senior Data Engineer, and now Director of Strategic Projects, reporting to the CEO.",
  },
];
---

<BaseLayout>
  <a class="skip-link" href="#main">Skip to content</a>
  <Header />

  <main id="main">
    <div id="top" class="shell">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="mono eyebrow">Director, Strategic Projects · Sitemetric</p>
          <h1 id="hero-title" class="display">Michael Gilsinan</h1>
          <p class="lede">
            I analyze operations, uncover insights in data, build the infrastructure to support them, and turn those insights into action. Today, I do that at
            <a class="lede-link" href="https://www.sitemetric.com/" target="_blank" rel="noreferrer noopener">Sitemetric</a>,
            building data systems and analytics for an AI-powered construction intelligence platform used on many of the country's largest construction projects. Before that, I founded a music school while still an undergraduate
            and grew it into two locations across New York City and New Jersey, delivering
            more than 300 classes each week with a staff of over 30.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#work">
              See the work
              <span class="arrow" aria-hidden="true">→</span>
            </a>
{/*
            <a class="button secondary" href={STACK_URL} target="_blank" rel="noreferrer noopener">
              Stack on the App Store
              <span class="arrow" aria-hidden="true">↗</span>
            </a>
*/}
            <a class="button secondary" href={LINKEDIN} target="_blank" rel="noreferrer noopener">
              LinkedIn
            </a>
          </div>
        </div>

        <figure class="portrait">
          <Image
            src={portrait}
            alt="Michael Gilsinan"
            widths={[280, 460, 720]}
            sizes="(max-width: 900px) 260px, 380px"
            loading="eager"
            fetchpriority="high"
          />
          <figcaption class="mono">
            <span class="status-dot" aria-hidden="true"></span>
            New York, NY
          </figcaption>
        </figure>
      </section>

      <section class="section" id="work" aria-labelledby="work-title">
        <div class="section-head" data-reveal>
          <div>
            <p class="mono eyebrow">Work</p>
            <h2 id="work-title" class="headline">Three things worth pointing at.</h2>
          </div>
          <p class="section-index">01 / 03</p>
        </div>

        <div class="project-list">
          {
            projects.map((project) => (
              <article class={project.featured ? "project featured" : "project"} data-reveal>
                <div class="project-top">
                  <p class="project-label">{project.label}</p>
                </div>
                <div class="project-body">
                  <div>
                    <h3>{project.title}</h3>
                    <p>{project.text}</p>
                    <a
                      class="project-link"
                      href={project.link}
                      target="_blank"
                      rel="noreferrer noopener"
                    >
                      {project.linkLabel}
                      <span class="arrow" aria-hidden="true">
                        ↗
                      </span>
                    </a>
                  </div>
                  <div class="project-meta">
                    {project.meta.map((tag) => (
                      <span>{tag}</span>
                    ))}
                  </div>
                </div>
                {project.gallery && (
                  <div class="project-gallery">
                    {project.gallery.map((shot) => (
                      <figure class="shot">
                        <Image
                          src={shot.src}
                          alt={shot.alt}
                          widths={[240, 420]}
                          sizes="(max-width: 720px) 60vw, 240px"
                          loading="lazy"
                        />
                      </figure>
                    ))}
                  </div>
                )}
                {project.visuals && (
                  <div class="project-visuals">
                    {project.visuals.map((visual) => (
                      <figure class="project-visual">
                        <Image
                          src={visual.src}
                          alt={visual.alt}
                          widths={[420, 620, 840]}
                          sizes="(max-width: 720px) 92vw, 420px"
                          loading="lazy"
                        />
                        <figcaption class="mono">{visual.caption}</figcaption>
                      </figure>
                    ))}
                  </div>
                )}
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="background" aria-labelledby="background-title">
        <div class="section-head" data-reveal>
          <div>
            <p class="mono eyebrow">Background</p>
            <h2 id="background-title" class="headline">From founding a music school to building data infrastructure.</h2>
          </div>
          <p class="section-index">02 / 03</p>
        </div>

        <div class="timeline">
          {
            background.map((item) => (
              <div class="timeline-item" data-reveal>
                <p>{item.text}</p>
              </div>
            ))
          }
        </div>
      </section>

      <section class="section" id="contact" aria-labelledby="contact-title">
        <div class="section-head" data-reveal>
          <div>
            <p class="mono eyebrow">Contact</p>
          </div>
          <p class="section-index">03 / 03</p>
        </div>

        <div class="contact" data-reveal>
          <h2 id="contact-title" class="headline">Say hi.</h2>
          <p class="lede">
            Happy to talk about data, construction tech, running a services business, or
            anything I've shipped.
          </p>
          <div class="contact-actions">
            <a class="button primary" href={LINKEDIN} target="_blank" rel="noreferrer noopener">
              Connect on LinkedIn
              <span class="arrow" aria-hidden="true">→</span>
            </a>
            <a class="button secondary" href={GITHUB} target="_blank" rel="noreferrer noopener">
              GitHub
              <span class="arrow" aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
