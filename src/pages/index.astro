---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import portrait from "../assets/michael-gilsinan.png";

const LINKEDIN = "https://www.linkedin.com/in/michaelgilsinan";
const GITHUB = "https://github.com/mgilsinan";
const STACK_URL = "https://apps.apple.com/us/app/st-ck/id6768111057";

const projects = [
  {
    label: "2020 — present · Sitemetric",
    title: "Data infrastructure for a construction intelligence platform",
    text: "Sitemetric now tracks 1M+ workers and 16,000+ contractors across 40 states. I have owned parts of the data infrastructure and help customers understand and use the data — pipelines, reporting, and turning what the numbers show into operating decisions. Started in customer experience (SVP), moved into Senior Data Engineer, and now report to the CEO on strategic projects.",
    meta: ["Data infrastructure", "Reporting", "GTM", "Construction tech"],
    link: "https://www.sitemetric.com/",
    linkLabel: "Sitemetric",
    featured: true,
  },
  {
    label: "2010 — 2020 · Founder",
    title: "Fort Lee School of Music",
    text: "Opened it in the second year of my undergrad. Grew it to two locations — Fort Lee, NJ and New York, NY — including a full gut renovation of a street-level NYC retail space. At peak, thirty teachers and staff running 300+ classes a week, plus event work at the DiMenna Center, Baruch College, and other venues.",
    meta: ["Founder", "Two locations", "30 staff", "300+ classes / week"],
    link: "https://www.fortleemusicschool.com/",
    linkLabel: "Fort Lee School of Music",
  },
  {
    label: "Weekend project · iOS",
    title: "Stack",
    text: "A strength-training app I built for myself to keep shipping. React Native via Expo, backend on Railway, RevenueCat for subscription plumbing, Resend for transactional email, submitted through Xcode. Not chasing users — the point is the practice of building something end-to-end.",
    meta: ["React Native", "Expo", "Railway", "RevenueCat", "Resend"],
    link: STACK_URL,
    linkLabel: "View on App Store",
  },
];

const background = [
  {
    text: "Started college as a performance major. By my second year, I had founded Fort Lee School of Music and was hiring classmates. Over the next decade, we expanded to two locations, employed 30 staff, and delivered more than 300 classes per week.",
  },
  {
    text: "During the COVID shutdown, I returned to school for a second master's degree in Applied Analytics with a concentration in Management. One class remains; expected to graduate in Fall 2026.",
  },
  {
    text: "Joined Sitemetric in 2020 as a Data Control Officer. Since then, I've served as SVP of Customer Experience, Senior Data Engineer, and now Director of Strategic Projects, reporting to the CEO.",
  },
];
---

<BaseLayout>
  <a class="skip-link" href="#main">Skip to content</a>
  <Header />

  <main id="main">
    <div id="top" class="shell">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="mono eyebrow">Director, Strategic Projects · Sitemetric</p>
          <h1 id="hero-title" class="display">Michael Gilsinan</h1>
          <p class="lede">
            I analyze operations, uncover insights in data, build the infrastructure to
            support them, and turn those insights into action. I currently work at
            <a class="lede-link" href="https://www.sitemetric.com/" target="_blank" rel="noreferrer noopener">Sitemetric</a>,
            a construction technology company serving more than 1 million workers and 16,000 contractors across
            40 states. Before that, I founded a music school while still an undergraduate
            and grew it into two locations across New York City and New Jersey, delivering
            more than 300 classes each week with a staff of over 30.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#work">
              See the work
              <span class="arrow" aria-hidden="true">→</span>
            </a>
{/*
            <a class="button secondary" href={STACK_URL} target="_blank" rel="noreferrer noopener">
              Stack on the App Store
              <span class="arrow" aria-hidden="true">↗</span>
            </a>
*/}
            <a class="button secondary" href={LINKEDIN} target="_blank" rel="noreferrer noopener">
              LinkedIn
            </a>
          </div>
        </div>

        <figure class="portrait">
          <Image
            src={portrait}
            alt="Michael Gilsinan"
            widths={[280, 460, 720]}
            sizes="(max-width: 900px) 260px, 380px"
            loading="eager"
            fetchpriority="high"
          />
          <figcaption class="mono">
            <span class="status-dot" aria-hidden="true"></span>
            New York, NY
          </figcaption>
        </figure>
      </section>

      <section class="section" id="work" aria-labelledby="work-title">
        <div class="section-head" data-reveal>
          <div>
            <p class="mono eyebrow">Work</p>
            <h2 id="work-title" class="headline">Three things worth pointing at.</h2>
          </div>
          <p class="section-index">01 / 03</p>
        </div>

        <div class="project-list">
          {
            projects.map((project) => (
              <article class={project.featured ? "project featured" : "project"} data-reveal>
                <div class="project-top">
                  <p class="project-label">{project.label}</p>
                </div>
                <div class="project-body">
                  <div>
                    <h3>{project.title}</h3>
                    <p>{project.text}</p>
                    <a
                      class="project-link"
                      href={project.link}
                      target="_blank"
                      rel="noreferrer noopener"
                    >
                      {project.linkLabel}
                      <span class="arrow" aria-hidden="true">
                        ↗
                      </span>
                    </a>
                  </div>
                  <div class="project-meta">
                    {project.meta.map((tag) => (
                      <span>{tag}</span>
                    ))}
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="background" aria-labelledby="background-title">
        <div class="section-head" data-reveal>
          <div>
            <p class="mono eyebrow">Background</p>
            <h2 id="background-title" class="headline">From founding a music school to building data infrastructure.</h2>
          </div>
          <p class="section-index">02 / 03</p>
        </div>

        <div class="timeline">
          {
            background.map((item) => (
              <div class="timeline-item" data-reveal>
                <p>{item.text}</p>
              </div>
            ))
          }
        </div>
      </section>

      <section class="section" id="contact" aria-labelledby="contact-title">
        <div class="section-head" data-reveal>
          <div>
            <p class="mono eyebrow">Contact</p>
          </div>
          <p class="section-index">03 / 03</p>
        </div>

        <div class="contact" data-reveal>
          <h2 id="contact-title" class="headline">Say hi.</h2>
          <p class="lede">
            Happy to talk about data, construction tech, running a services business, or
            anything I've shipped.
          </p>
          <div class="contact-actions">
            <a class="button primary" href={LINKEDIN} target="_blank" rel="noreferrer noopener">
              Connect on LinkedIn
              <span class="arrow" aria-hidden="true">→</span>
            </a>
            <a class="button secondary" href={GITHUB} target="_blank" rel="noreferrer noopener">
              GitHub
              <span class="arrow" aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
